{
  "name": "ic-reactor",
  "version": "3.7.0",
  "type": "module",
  "private": true,
  "description": "The modern, type-safe library for building Internet Computer applications",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "test": "pnpm -r --filter \"./packages/**\" test",
    "test-e2e": "cd e2e && bash ./test.sh",
    "docs:build": "cd docs && pnpm build",
    "docs:preview": "cd docs && pnpm preview",
    "size": "pnpm -r --filter \"./packages/**\" run size",
    "size:analyze": "pnpm -r --filter \"./packages/**\" run analyze",
    "prepublish:check": "pnpm -r --filter @ic-reactor/core --filter @ic-reactor/react --filter @ic-reactor/candid build && pnpm -r --filter @ic-reactor/core --filter @ic-reactor/react --filter @ic-reactor/candid test && pnpm -r --filter @ic-reactor/core --filter @ic-reactor/react --filter @ic-reactor/candid size",
    "pack:check": "pnpm -r --filter \"./packages/**\" --filter \"!@ic-reactor/cod\" exec npm pack --dry-run",
    "sync:examples": "node scripts/sync-example-versions.js",
    "typecheck:examples": "node scripts/typecheck-examples.js",
    "check:ai-context": "node scripts/check-ai-context.js",
    "release": "node scripts/release.js",
    "release:tools": "node scripts/release-tools.js",
    "clean": "node scripts/clean-node-modules.js",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md,mdx,css,scss,html}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,md,mdx,css,scss,html}\"",
    "format:staged": "pnpm -r --filter './packages/**' exec prettier --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,scss,html}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "internet-computer",
    "dfinity",
    "icp",
    "react",
    "typescript",
    "tanstack-query"
  ],
  "author": "Behrad Deylami",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/B3Pay/ic-reactor.git"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@dfinity/agent": "npm:@icp-sdk/core/agent@^5.2.0",
      "@dfinity/candid": "npm:@icp-sdk/core/candid@^5.2.0",
      "@dfinity/principal": "npm:@icp-sdk/core/principal@^5.2.0",
      "@dfinity/identity": "npm:@icp-sdk/core/identity@^5.2.0",
      "axios": "1.16.0",
      "brace-expansion": "5.0.6",
      "devalue": "5.8.1",
      "fast-uri": "3.1.2",
      "h3": "1.15.9",
      "picomatch": "4.0.4",
      "postcss": "8.5.12",
      "minimatch": "10.2.5",
      "rollup": "4.60.1",
      "smol-toml": "1.6.1",
      "svgo": "4.0.1",
      "tar": "7.5.20",
      "yaml": "2.8.3",
      "follow-redirects": "1.16.0",
      "undici": "7.28.0",
      "ws": "8.21.0"
    },
    "ignoredBuiltDependencies": [
      "wasm-pack"
    ]
  }
}
