type Post = record {
    id: nat;
    title: text;
    content: text;
    category: text;
    author: text;
    handle: text;
    avatar: text;
    timestamp: text;
    likes: nat;
    reposts: nat;
    replies: nat;
    views: nat;
};

type PostsResponse = record {
    posts: vec Post;
    next_cursor: opt nat;
};

service : {
    get_posts: (category: opt text, cursor: nat, limit: nat) -> (PostsResponse) query;
}
