{
  "name": "ic-rust-nextjs",
  "version": "1.0.1",
  "private": true,
  "author": "b3hr4d <b3hr4d@live.com>",
  "description": "Internet Computer Rust + NextJS Template",
  "keywords": [
    "nextjs",
    "rust",
    "internet computer",
    "icp",
    "starter",
    "dfinity"
  ],
  "scripts": {
    "install:all": "pnpm install && pnpm ic-wasm:install && pnpm candid:install",
    "candid:install": "cargo install candid-extractor",
    "ic-wasm:install": "cargo install ic-wasm",
    "build": "next build --webpack",
    "start": "next start",
    "export": "next build --webpack",
    "dev": "next dev --webpack",
    "dfx:start": "dfx start --background --clean",
    "dfx:stop": "dfx stop",
    "dfx:pull": "dfx deps pull",
    "dfx:build": "dfx build",
    "deploy": "dfx deploy",
    "generate": "dfx generate"
  },
  "dependencies": {
    "@ic-reactor/react": "^3.6.0",
    "@icp-sdk/auth": "^7.1.0",
    "@icp-sdk/core": "^5.4.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "next": "^16.2.10",
    "postcss": "^8.5.18",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
