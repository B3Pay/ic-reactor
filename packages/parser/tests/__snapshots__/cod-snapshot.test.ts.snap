export default c.service({})"
`;

exports[`COD Rust renderer snapshots > generates metadata from docs and validation tags 1`] = `
"import { c } from "@ic-reactor/cod"

export const Account = c.record({
  owner: c.principal().describe("Owner principal."),
  email: c.email("Invalid email address").describe("Contact email."),
}).describe("Account that receives tokens.")
export type Account = c.infer<typeof Account>
export default c.service({
  balance: c.query([Account], c.nat()).describe("Return an account balance."),
}).describe("Ledger service.")"
`;

exports[`COD Rust renderer snapshots > generates quoted names tuples and multi-return methods 1`] = `
"import { c } from "@ic-reactor/cod"

export const Coordinates = c.tuple([c.float64(), c.float64()])
export type Coordinates = c.infer<typeof Coordinates>
export const Status = c.variant({ Err: c.text(), Ready: c.null() })
export type Status = c.infer<typeof Status>
export default c.service({
  "default": c.update([c.nat8()]),
  "icrc-1-name": c.query([], c.text()),
  locate: c.query([c.text()], [Coordinates, Status]),
})"
`;

exports[`COD Rust renderer snapshots > generates regex helpers for pattern validators 1`] = `
"import { c } from "@ic-reactor/cod"

export const Profile = c.record({
  code: c.regex("^[A-Z]{3}$"),
  slug: c.regex("^[a-z0-9-]+$").describe("Slug used in URLs."),
})
export type Profile = c.infer<typeof Profile>
export default c.service({})"
`;
