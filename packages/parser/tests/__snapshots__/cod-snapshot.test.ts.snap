// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`COD Rust renderer snapshots > generates Zod-style ISO namespace helpers 1`] = `
"import { c } from "@ic-reactor/cod"

export const IsoFormats = c.record({
  day: c.iso.date(),
  updated_at: c.iso.datetime(),
  starts_at: c.iso.time(),
  created_at: c.iso.datetime(),
  length: c.iso.duration(),
})
export type IsoFormats = c.infer<typeof IsoFormats>
export default c.service({})"
`;

exports[`COD Rust renderer snapshots > generates Zod-style string format helpers 1`] = `
"import { c } from "@ic-reactor/cod"

export const StringFormats = c.record({
  hex: c.hex(),
  jwt: c.jwt(),
  url: c.url(),
  nanoid: c.nanoid(),
  http_url: c.httpUrl(),
  cuid: c.cuid(),
  guid: c.guid(),
  ulid: c.ulid(),
  uuid: c.uuid(),
  cuid2: c.cuid2(),
  hostname: c.hostname(),
  base64: c.base64(),
  email: c.email(),
  emoji: c.emoji(),
  base64url: c.base64url(),
  phone: c.e164(),
})
export type StringFormats = c.infer<typeof StringFormats>
export default c.service({})"
`;

exports[`COD Rust renderer snapshots > generates a default service contract 1`] = `
"import { c } from "@ic-reactor/cod"

export const Account = c.record({
  owner: c.principal(),
  subaccount: c.opt(c.blob()),
})
export type Account = c.infer<typeof Account>
export const TransferResult = c.variant({ Ok: c.nat(), Err: c.text() })
export type TransferResult = c.infer<typeof TransferResult>
export default c.service({
  icrc1_balance_of: c.query([Account], c.nat()),
  icrc1_transfer: c.update([Account], TransferResult),
})"
`;

exports[`COD Rust renderer snapshots > generates custom format metadata instead of dynamic helpers 1`] = `
"import { c } from "@ic-reactor/cod"

export const Profile = c.record({
  slug: c.text().meta(
    {"docs":["@format slug Invalid slug"],"validation":{"format":{"type":"slug","regex":"^[a-z0-9-]+$","errorMessage":"Invalid slug"}}}
  ),
  email: c.text().meta(
    {"docs":["@format email"],"validation":{"format":{"type":"email","regex":"^[^@]+@[^@]+$","jsonSchemaFormat":"email","errorMessage":"Must be a valid email address"}}}
  ),
})
export type Profile = c.infer<typeof Profile>
export default c.service({})"
`;

